# .env.example — Copy to .env and fill in values. .env is git-ignored.
#
# Used by:
#   deploy-grafana.sh   — GRAFANA_TOKEN + GIT_SYNC_TOKEN for automatic Git Sync push
#   push-git-sync.sh    — all three vars for standalone Git Sync push

# URL of the running Grafana instance.
# Used by push-git-sync.sh for standalone pushes.
# For local access via port-forward: http://localhost:3000
# For direct cluster access: http://grafana.metrics.svc.cluster.local
GRAFANA_URL=http://localhost:3000

# (optional) Grafana service account token with Admin role.
# deploy-grafana.sh derives this automatically from the admin secret at deploy time,
# so you only need to set it if you want to use push-git-sync.sh against a remote
# instance or skip the automatic derivation.
# Create one in Grafana UI: Administration > Service Accounts > Add service account token
# GRAFANA_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxx

# GitHub Personal Access Token (classic or fine-grained) with read access to this repo.
# Used by Grafana's Git Sync to clone and poll the repository.
# Fine-grained PAT: grant Contents: Read (and Write if you want bidirectional sync).
GIT_SYNC_TOKEN=<github_pat_xxx>
