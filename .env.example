# .env.example — Copy to .env and fill in values. .env is git-ignored.
#
# Used by:
#   deploy-grafana.sh       — no secrets required; derives admin token automatically
#   configure-git-sync.sh   — GIT_SYNC_TOKEN required

# GitHub Personal Access Token (classic or fine-grained) with read access to this repo.
# Used by Grafana's Git Sync to clone and poll the repository.
# Fine-grained PAT: grant Contents: Read (and Write if you want bidirectional sync).
GIT_SYNC_TOKEN=<github_pat_xxx>

# (optional) Initial Grafana admin password.
# If unset, Helm generates a random one (retrieve with:
#   kubectl get secret grafana -n metrics -o jsonpath='{.data.admin-password}' | base64 --decode
# )
# GRAFANA_ADMIN_PASSWORD=changeme
